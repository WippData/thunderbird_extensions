{
  "manifest_version": 2,
  "name": "Pinned Tabs",
  "version": "0.1.0",
  "description": "Pin Thunderbird tabs and automatically reopen them after accidental close when Thunderbird exposes enough metadata to restore them.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pinned-tabs-reopener@local",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/pin-16.svg",
    "32": "icons/pin-32.svg"
  },
  "browser_action": {
    "default_title": "Pinned Tabs",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/pin-16.svg",
      "32": "icons/pin-32.svg"
    },
    "allowed_spaces": []
  }
}
